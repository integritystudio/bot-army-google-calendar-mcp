73:           removeLabelIds: [GMAIL_UNREAD, GMAIL_INBOX]
74:         }
75:       });
76:       totalArchived += batch.length;
77:     }
78: 
79:     console.log(`✅ Archived and marked ${oldIds.length} as read\n`);
