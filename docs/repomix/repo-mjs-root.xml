 22:           name: LABEL_BILLING,
 23:           labelListVisibility: 'labelShow',
 24:           messageListVisibility: 'show'
 25:         }
 26:       });
 27:       billingLabelId = createBillingResponse.data.id;
 28:       console.log('✅ Created label: Billing\n');
 29:     }
