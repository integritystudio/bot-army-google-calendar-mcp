<file path="create-meet-notes-filter.mjs">
 1: import { createGmailClient } from './lib/gmail-client.mjs';
 2: import { USER_ID, GMAIL_INBOX, LABEL_MEETING_NOTES } from './lib/constants.mjs';
 3: 
 4: async function createMeetNotesFilter() {
 5:   const gmail = createGmailClient();
 6: 
 7:   console.log('📝 CREATING GOOGLE MEET NOTES FILTER\n');
 8:   console.log('═'.repeat(80) + '\n');
 9: 
10:   try {
11:     let notesLabelId;
12:     const labelsResponse = await gmail.users.labels.list({ userId: USER_ID });
13:     const existingLabel = labelsResponse.data.labels.find(l => l.name === LABEL_MEETING_NOTES);
14: 
15:     if (existingLabel) {
16:       notesLabelId = existingLabel.id;
17:       console.log('✅ Using existing label: Meeting Notes\n');
18:     } else {
19:       const createLabelResponse = await gmail.users.labels.create({
20:         userId: USER_ID,
21:         requestBody: {
22:           name: LABEL_MEETING_NOTES,
23:           labelListVisibility: 'labelShow',
24:           messageListVisibility: 'show'
25:         }
26:       });
27:       notesLabelId = createLabelResponse.data.id;
28:       console.log('✅ Created label: Meeting Notes\n');
29:     }
30: 
31:     await gmail.users.settings.filters.create({
32:       userId: USER_ID,
33:       requestBody: {
34:         criteria: {
35:           query: 'from:meetings-noreply@google.com subject:Notes'
36:         },
37:         action: {
38:           addLabelIds: [notesLabelId],
39:           removeLabelIds: [GMAIL_INBOX]
40:         }
41:       }
42:     });
43:     console.log('✅ Filter created for future Google Meet notes\n');
44: 
45:     const searchResponse = await gmail.users.messages.list({
46:       userId: USER_ID,
47:       q: 'is:unread from:meetings-noreply@google.com subject:Notes'
48:     });
49: 
50:     const messageIds = searchResponse.data.messages || [];
51:     console.log(`📊 Found ${messageIds.length} existing unread Google Meet notes\n`);
52: 
53:     if (messageIds.length > 0) {
54:       const batchSize = 50;
55:       for (let i = 0; i < messageIds.length; i += batchSize) {
56:         const batch = messageIds.slice(i, i + batchSize);
57: 
58:         await gmail.users.messages.batchModify({
59:           userId: USER_ID,
60:           requestBody: {
61:             ids: batch.map(m => m.id),
62:             addLabelIds: [notesLabelId],
63:             removeLabelIds: [GMAIL_INBOX]
64:           }
65:         });
66: 
67:         const processed = i + batch.length;
68:         console.log(`✅ Applied to ${processed}/${messageIds.length}`);
69:       }
70:     }
71: 
72:     console.log('\n' + '═'.repeat(80));
73:     console.log('COMPLETE\n');
74:     console.log(`✅ Label: Meeting Notes`);
75:     console.log(`✅ Filter: from:meetings-noreply@google.com subject:Notes`);
76:     console.log(`✅ Applied to: ${messageIds.length} existing emails`);
77:     console.log(`✅ Future Google Meet notes will auto-label and skip inbox\n`);
78:     console.log('═'.repeat(80) + '\n');
79: 
80:   } catch (error) {
81:     console.error('❌ Error:', error.message);
82:     process.exit(1);
83:   }
84: }
85: 
86: createMeetNotesFilter().catch(error => {
87:   console.error('❌ Error:', error.message);
88:   process.exit(1);
89: });
</file>

