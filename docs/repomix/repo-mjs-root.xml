<file path="filter-events-by-date.mjs">
  1: import { createGmailClient } from './lib/gmail-client.mjs';
  2: import { USER_ID, GMAIL_INBOX, LABEL_EVENTS, LABEL_KEEP_IMPORTANT } from './lib/constants.mjs';
  3: import { classifyEmail, getGmailAction } from './lib/date-based-filter.mjs';
  4: import { getHeader } from './lib/email-utils.mjs';
  5: 
  6: async function filterEventsByDate() {
  7:   const gmail = createGmailClient();
  8: 
  9:   console.log('📅 FILTERING EVENTS BY DATE (WITH DATE-BASED ARCHIVE)\n');
 10:   console.log('═'.repeat(80) + '\n');
 11: 
 12:   try {
 13:     const labelsResponse = await gmail.users.labels.list({ userId: USER_ID });
 14:     const eventsLabel = labelsResponse.data.labels.find(l => l.name === LABEL_EVENTS);
 15:     const keepImportantLabel = labelsResponse.data.labels.find(l => l.name === LABEL_KEEP_IMPORTANT);
 16: 
 17:     if (!eventsLabel) {
 18:       console.log('❌ Events label not found\n');
 19:       process.exit(1);
 20:     }
 21: 
 22:     const eventsLabelId = eventsLabel.id;
 23:     const keepImportantLabelId = keepImportantLabel?.id;
 24: 
 25:     // Event email patterns
 26:     const eventKeywords = '(event OR meeting OR conference OR workshop OR seminar OR webinar OR presentation OR summit OR expo OR networking OR panel OR forum OR gathering OR ceremony OR celebration)';
 27:     const eventSenders = '(meetup OR eventbrite OR "international house" OR calendly OR calendar)';
 28: 
 29:     console.log('STEP 1: Finding event-like unread emails\n');
 30: 
 31:     const searchQuery = `is:unread (subject:${eventKeywords} OR from:${eventSenders}) ${keepImportantLabelId ? `-label:"${LABEL_KEEP_IMPORTANT}"` : ''}`;
 32: 
 33:     const searchResponse = await gmail.users.messages.list({
 34:       userId: USER_ID,
 35:       q: searchQuery,
 36:       maxResults: 100
 37:     });
 38: 
 39:     const messageIds = searchResponse.data.messages || [];
 40:     console.log(`Found ${messageIds.length} event-like emails\n`);
 41: 
 42:     if (messageIds.length === 0) {
 43:       console.log('No event emails to process\n');
 44:       return;
 45:     }
 46: 
 47:     console.log('STEP 2: Classifying events by date\n');
 48: 
 49:     const fullMsgs = await Promise.all(
 50:       messageIds.map(msg =>
 51:         gmail.users.messages.get({ userId: USER_ID, id: msg.id, format: 'full' })
 52:           .catch(error => {
 53:             console.log(`⚠️  Error processing email: ${error.message}`);
 54:             return null;
 55:           })
 56:       )
 57:     );
 58: 
 59:     const futureIds = [];
 60:     const pastIds = [];
 61: 
 62:     for (const fullMsg of fullMsgs.filter(Boolean)) {
 63:       const headers = fullMsg.data.payload?.headers || [];
 64:       const subject = getHeader(headers, 'Subject');
 65: 
 66:       let body = '';
 67:       if (fullMsg.data.payload?.parts?.[0]?.body?.data) {
 68:         body = Buffer.from(fullMsg.data.payload.parts[0].body.data, 'base64').toString('utf-8');
 69:       } else if (fullMsg.data.payload?.body?.data) {
 70:         body = Buffer.from(fullMsg.data.payload.body.data, 'base64').toString('utf-8');
 71:       }
 72: 
 73:       const classification = classifyEmail(subject, body);
 74: 
 75:       if (classification.status === 'future') {
 76:         futureIds.push(fullMsg.data.id);
 77:       } else if (classification.status === 'past') {
 78:         pastIds.push(fullMsg.data.id);
 79:       }
 80:     }
 81: 
 82:     const unknownCount = messageIds.length - futureIds.length - pastIds.length;
 83: 
 84:     console.log(`  Future events: ${futureIds.length}`);
 85:     console.log(`  Past events: ${pastIds.length}`);
 86:     console.log(`  Unknown date: ${unknownCount}\n`);
