      'from:news@alphasignal.ai',
      'from:noreply@email.openai.com',
      'from:lukak@storylane.io',
      'from:no-reply@email.claude.com'
    ]
  },
  {
    label: 'Communities',
    queries: [
      'from:wtm@technovation.org'
    ]
  },
  {
    label: 'Keep Important',
    queries: [
      'from:capitalcity@a.helpfulvillage.com'
    ]
  }
];

