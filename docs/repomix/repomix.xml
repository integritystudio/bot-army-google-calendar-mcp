# input file paths
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INPUT_DIR="$SCRIPT_DIR/generate-"
TOKEN_TREE_SCRIPT="$INPUT_DIR$TREE_FILE.sh"
COMPRESS_SCRIPT="$INPUT_DIR$COMPRESSED_FILE.sh"
