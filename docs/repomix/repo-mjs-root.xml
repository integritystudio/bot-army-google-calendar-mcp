  2: import { USER_ID, LABEL_PERFORMANCE_TRACKING, LABEL_NEWSLETTERS_SUBJECT_BASED } from './lib/constants.mjs';
  3: 
  4: async function createPerformanceTrackingLabel() {
  5:   const gmail = createGmailClient();
  6: 
  7:   console.log('📊 CREATING PERFORMANCE TRACKING LABEL\n');
  8:   console.log('═'.repeat(80) + '\n');
  9: 
 10:   // Pre-fetch existing labels to avoid N+1 queries
 11:   const existingLabelsRes = await gmail.users.labels.list({
 12:     userId: USER_ID,
 13:     fields: 'labels(id,name)',
 14:   });
 15:   const existingLabelMap = new Map(
 16:     existingLabelsRes.data.labels.map(l => [l.name, l.id])
 17:   );
 18: 
 19:   console.log('1️⃣  CREATING LABEL: Performance Tracking\n');
 20: 
 21:   let perfLabelId;
 22: 
 23:   try {
 24:     const response = await gmail.users.labels.create({
 25:       userId: USER_ID,
 26:       requestBody: {
 27:         name: LABEL_PERFORMANCE_TRACKING,
 28:         labelListVisibility: 'labelShow',
 29:         messageListVisibility: 'show',
 30:       },
 31:     });
 32: 
 33:     console.log('✅ Label created successfully!');
 34:     console.log(`   Name: ${response.data.name}`);
 35:     console.log(`   ID: ${response.data.id}\n`);
 36:     perfLabelId = response.data.id;
 37: 
 38:   } catch (error) {
 39:     if (error.message.includes('exists') || error.message.includes('conflicts')) {
 40:       console.log('⚠️  Label already exists: Performance Tracking\n');
 41:       const existingId = existingLabelMap.get(LABEL_PERFORMANCE_TRACKING);
 42:       if (existingId) {
 43:         console.log(`   ID: ${existingId}\n`);
 44:         perfLabelId = existingId;
 45:       }
 46:     } else {
 47:       console.error('❌ Error creating label:', error.message);
 48:       process.exit(1);
 49:     }
 50:   }
 51: 
 52:   console.log('═'.repeat(80));
 53:   console.log('\n2️⃣  MOVING SENTRY UPDATES FROM NEWSLETTER TO PERFORMANCE TRACKING\n');
 54: 
 55:   const sentryPatterns = [
 56:     'from:noreply@md.getsentry.com',
 57:     'subject:Sentry OR subject:"TCAD-SCRAPER-BACKEND"',
 58:   ];
 59: 
 60:   const newsletterLabelId = existingLabelMap.get(LABEL_NEWSLETTERS_SUBJECT_BASED);
 61:   let totalRelabeled = 0;
 62: 
 63:   for (const query of sentryPatterns) {
 64:     try {
 65:       const searchResult = await gmail.users.messages.list({
 66:         userId: USER_ID,
 67:         q: query,
 68:         maxResults: 100,
 69:       });
 70: 
 71:       if (!searchResult.data.messages) continue;
 72: 
 73:       const messageIds = searchResult.data.messages.map(m => m.id);
 74:       const count = messageIds.length;
 75: 
 76:       if (count > 0) {
 77:         await gmail.users.messages.batchModify({
 78:           userId: USER_ID,
 79:           requestBody: {
 80:             ids: messageIds,
 81:             addLabelIds: [perfLabelId],
 82:             removeLabelIds: [newsletterLabelId],
 83:           },
 84:         });
 85: 
 86:         console.log(`  ✅ Relabeled ${count} emails matching: "${query.substring(0, 50)}..."`);
 87:         console.log(`     Added: Performance Tracking`);
 88:         console.log(`     Removed: Newsletters/Subject-Based\n`);
 89:         totalRelabeled += count;
 90:       }
 91:     } catch (error) {
 92:       console.log(`  ⚠️  Error with "${query}": ${error.message}`);
 93:     }
 94:   }
 95: 
 96:   console.log(`  📊 Total relabeled: ${totalRelabeled} emails\n`);
 97: 
 98:   console.log('═'.repeat(80));
 99:   console.log('\n3️⃣  CREATING AUTO-LABEL FILTER FOR SENTRY\n');
100: 
101:   const filters = [
102:     {
103:       name: 'Sentry Error Tracking',
104:       criteria: { from: 'noreply@md.getsentry.com' },
105:     },
106:     {
107:       name: 'Sentry Alerts & Reports',
108:       criteria: { subject: 'Sentry OR "TCAD-SCRAPER-BACKEND"' },
109:     },
110:   ];
111: 
112:   let filtersCreated = 0;
113: 
114:   for (const filter of filters) {
115:     try {
116:       const response = await gmail.users.settings.filters.create({
117:         userId: USER_ID,
118:         requestBody: {
119:           criteria: filter.criteria,
120:           action: {
121:             addLabelIds: [perfLabelId],
122:           },
123:         },
124:       });
125: 
126:       console.log(`  ✅ Filter created: ${filter.name}`);
127:       console.log(`     ID: ${response.data.id}\n`);
128:       filtersCreated++;
129:     } catch (error) {
130:       if (error.message.includes('exists')) {
131:         console.log(`  ℹ️  Filter already exists: ${filter.name}`);
132:       } else {
133:         console.log(`  ⚠️  Error creating filter "${filter.name}": ${error.message}`);
134:       }
135:     }
136:   }
137: 
138:   console.log('═'.repeat(80));
139:   console.log('\n✨ PERFORMANCE TRACKING LABEL COMPLETE\n');
140:   console.log(`  📌 Sentry emails relabeled: ${totalRelabeled}`);
141:   console.log(`  🔄 Filters created: ${filtersCreated}`);
142:   console.log(`  📂 Label: Performance Tracking (${perfLabelId})`);
143:   console.log('\n💡 Sentry updates are now tracked under Performance Tracking, not Newsletters!\n');
144:   console.log('📂 New Top-Level Label:');
145:   console.log('   Performance Tracking');
146:   console.log('   ├── Sentry Error Reports');
147:   console.log('   ├── Weekly Reports');
148:   console.log('   └── (other performance data)\n');
149: }
150: 
151: createPerformanceTrackingLabel().catch(error => {
152:   console.error('❌ Error:', error.message);
153:   process.exit(1);
154: });
</file>

