  1: import { createGmailClient } from './lib/gmail-client.mjs';
  2: import { USER_ID, LABEL_EVENTS_COMMUNITY, LABEL_EVENTS_COMMUNITY_CREATIVE_ARTS, LABEL_EVENTS_COMMUNITY_TECH_PROFESSIONAL, LABEL_EVENTS_COMMUNITY_SPIRITUAL_WELLNESS, LABEL_EVENTS_COMMUNITY_NETWORKING, LABEL_EVENTS_COMMUNITY_LEARNING_EDUCATION, LABEL_EVENTS_COMMUNITY_SOCIAL_RECREATION, LABEL_EVENTS_COMMUNITY_FOOD_DINING } from './lib/constants.mjs';
  3: import { getHeader } from './lib/email-utils.mjs';
  4: import { buildLabelCache } from './lib/gmail-label-utils.mjs';
  5: 
  6: async function labelRemainingCommunity() {
  7:   const gmail = createGmailClient();
  8: 
  9:   console.log('📂 LABELING REMAINING COMMUNITY EMAILS\n');
 10:   console.log('═'.repeat(80) + '\n');
 11: 
 12:   const labelCache = await buildLabelCache(gmail);
 13:   const communityLabelId = labelCache.get(LABEL_EVENTS_COMMUNITY);
 14: 
 15:   const allMessages = await gmail.users.messages.list({
 16:     userId: USER_ID,
 17:     labelIds: [communityLabelId],
 18:     maxResults: 500
 19:   });
 20: 
 21:   const subLabelIds = [
 22:     LABEL_EVENTS_COMMUNITY_CREATIVE_ARTS,
 23:     LABEL_EVENTS_COMMUNITY_TECH_PROFESSIONAL,
 24:     LABEL_EVENTS_COMMUNITY_SPIRITUAL_WELLNESS,
 25:     LABEL_EVENTS_COMMUNITY_NETWORKING,
 26:     LABEL_EVENTS_COMMUNITY_LEARNING_EDUCATION,
 27:     LABEL_EVENTS_COMMUNITY_SOCIAL_RECREATION,
 28:     LABEL_EVENTS_COMMUNITY_FOOD_DINING,
 29:   ].map(name => labelCache.get(name)).filter(Boolean);
 30:   const labeledMessages = await Promise.all(
 31:     subLabelIds.map(id =>
 32:       gmail.users.messages.list({ userId: USER_ID, labelIds: [id], maxResults: 500 })
 33:     )
 34:   );
 35: 
 36:   const labeledIds = new Set();
 37:   labeledMessages.forEach(result => {
 38:     result.data.messages?.forEach(m => labeledIds.add(m.id));
 39:   });
 40: 
 41:   const unlabeled = allMessages.data.messages?.filter(m => !labeledIds.has(m.id)) || [];
 42:   console.log(`Unlabeled emails to process: ${unlabeled.length}\n`);
 43: 
 44:   const categoryPatterns = {
 45:     [labelCache.get(LABEL_EVENTS_COMMUNITY_CREATIVE_ARTS)]: {
 46:       name: 'Creative-Arts',
 47:       patterns: [/art|drawing|creative|sketch|music|design|performance|painting/i]
 48:     },
 49:     [labelCache.get(LABEL_EVENTS_COMMUNITY_TECH_PROFESSIONAL)]: {
 50:       name: 'Tech-Professional',
 51:       patterns: [/tech|coding|development|robotics|ai|computer|data|engineering|elasticsearch|infra|platform|search|governance|rule/i]
 52:     },
 53:     [labelCache.get(LABEL_EVENTS_COMMUNITY_SPIRITUAL_WELLNESS)]: {
 54:       name: 'Spiritual-Wellness',
 55:       patterns: [/astrology|psychic|meditation|healing|yoga|zen|conscious|spiritual|energy|chakra|reiki|enlightenment|manifestation|angel|astrological|embodied|nervous system|stress/i]
 56:     },
 57:     [labelCache.get(LABEL_EVENTS_COMMUNITY_NETWORKING)]: {
 58:       name: 'Networking',
 59:       patterns: [/networking|community|group|meetup|connect|gathering|forum|mastermind|entrepreneur/i]
 60:     },
 61:     [labelCache.get(LABEL_EVENTS_COMMUNITY_LEARNING_EDUCATION)]: {
 62:       name: 'Learning-Education',
 63:       patterns: [/workshop|class|course|training|learn|skill|development|masterclass/i]
 64:     },
 65:     [labelCache.get(LABEL_EVENTS_COMMUNITY_SOCIAL_RECREATION)]: {
 66:       name: 'Social-Recreation',
 67:       patterns: [/game|night|party|gathering|social|fun|recreation|laugh|wine|trivia|taboo|closet/i]
 68:     },
 69:     [labelCache.get(LABEL_EVENTS_COMMUNITY_FOOD_DINING)]: {
 70:       name: 'Food-Dining',
 71:       patterns: [/lunch|dinner|food|restaurant|cafe|coffee|eat|brunch|feast/i]
 72:     },
 73:   };
 74: 
 75:   let labeledCount = 0;
 76: 
 77:   const fullMsgs = await Promise.all(
 78:     unlabeled.map(msgHeader =>
 79:       gmail.users.messages.get({
 80:         userId: USER_ID,
 81:         id: msgHeader.id,
 82:         format: 'metadata',
 83:         metadataHeaders: ['Subject']
 84:       }).catch(() => null)
 85:     )
 86:   );
 87: 
 88:   const emailsToLabel = [];
 89: 
 90:   for (const msg of fullMsgs.filter(Boolean)) {
 91:     const subject = getHeader(msg.data.payload.headers, 'Subject');
 92: 
 93:     let matchedLabelId = null;
 94:     for (const [labelId, config] of Object.entries(categoryPatterns)) {
 95:       for (const pattern of config.patterns) {
 96:         if (pattern.test(subject)) {
 97:           matchedLabelId = labelId;
 98:           break;
 99:         }
100:       }
101:       if (matchedLabelId) break;
102:     }
103: 
104:     if (matchedLabelId) {
105:       emailsToLabel.push({ id: msg.data.id, labelId: matchedLabelId, subject });
106:     }
107:   }
108: 
109:   const labelGroups = {};
110:   for (const email of emailsToLabel) {
111:     if (!labelGroups[email.labelId]) {
112:       labelGroups[email.labelId] = [];
113:     }
114:     labelGroups[email.labelId].push(email.id);
115:   }
116: 
117:   for (const [labelId, messageIds] of Object.entries(labelGroups)) {
118:     const displayName = categoryPatterns[labelId]?.name ?? labelId;
119:     try {
120:       await gmail.users.messages.batchModify({
121:         userId: USER_ID,
122:         requestBody: {
123:           ids: messageIds,
124:           addLabelIds: [labelId]
125:         }
126:       });
127: 
128:       console.log(`✅ ${displayName}: ${messageIds.length} emails`);
129:       labeledCount += messageIds.length;
130:     } catch (error) {
131:       console.log(`⚠️  ${displayName}: ${error.message}`);
132:     }
133:   }
134: 
135:   console.log(`\n📊 Total labeled: ${labeledCount} emails`);
136:   console.log(`❌ Unmatched: ${unlabeled.length - labeledCount} emails\n`);
137: 
138:   console.log('═'.repeat(80));
139:   console.log('\n✨ REMAINING COMMUNITY EMAILS LABELED\n');
140: }
141: 
142: labelRemainingCommunity().catch(error => {
143:   console.error('❌ Error:', error.message);
144:   process.exit(1);
145: });
</file>

