  1: import { createGmailClient } from './lib/gmail-client.mjs';
  2: import { extractDisplayName, getHeader } from './lib/email-utils.mjs';
  3: import {
  4:   USER_ID,
  5:   LABEL_SENTRY,
  6:   LABEL_KEEP_IMPORTANT,
  7:   LABEL_EVENTS,
  8:   LABEL_MONITORING,
  9:   LABEL_PRODUCT_UPDATES,
 10:   LABEL_COMMUNITIES,
 11:   LABEL_SERVICES,
 12:   LABEL_BILLING
 13: } from './lib/constants.mjs';
 14: 
 15: async function listUnreadEmails() {
 16:   const gmail = createGmailClient();
 17: 
 18:   console.log('📧 LISTING UNREAD EMAILS\n');
 19:   console.log('═'.repeat(80) + '\n');
 20: 
 21:   try {
 22:     const searchResponse = await gmail.users.messages.list({
 23:       userId: USER_ID,
 24:       q: 'is:unread',
 25:       maxResults: 500
 26:     });
 27: 
 28:     const messageIds = searchResponse.data.messages || [];
 29:     console.log(`Total unread: ${messageIds.length}\n`);
 30: 
 31:     if (messageIds.length === 0) {
 32:       console.log('✅ Inbox is clean!\n');
 33:       return;
 34:     }
 35: 
 36:     const labelsResponse = await gmail.users.labels.list({ userId: USER_ID });
 37:     const labels = labelsResponse.data.labels || [];
 38:     const labelMap = {};
 39:     labels.forEach(l => { labelMap[l.id] = l.name; });
 40: 
 41:     const fullMsgs = await Promise.all(
 42:       messageIds.map(msg =>
 43:         gmail.users.messages.get({
 44:           userId: USER_ID,
 45:           id: msg.id,
 46:           format: 'metadata',
 47:           metadataHeaders: ['Subject', 'From', 'Date']
 48:         })
 49:       )
 50:     );
 51: 
 52:     const emails = fullMsgs.map(fullMsg => {
 53:       const headers = fullMsg.data.payload?.headers || [];
 54:       return {
 55:         id: fullMsg.data.id,
 56:         subject: getHeader(headers, 'Subject', '(no subject)'),
 57:         from: getHeader(headers, 'From', '(unknown)'),
 58:         date: getHeader(headers, 'Date'),
 59:         labels: (fullMsg.data.labelIds || []).map(id => labelMap[id]).filter(Boolean)
 60:       };
 61:     });
 62: 
 63:     const categories = {
 64:       [LABEL_SENTRY]: [],
 65:       [LABEL_KEEP_IMPORTANT]: [],
 66:       [LABEL_EVENTS]: [],
 67:       [LABEL_MONITORING]: [],
 68:       [LABEL_PRODUCT_UPDATES]: [],
 69:       [LABEL_COMMUNITIES]: [],
 70:       [LABEL_SERVICES]: [],
 71:       [LABEL_BILLING]: [],
 72:       'Other': []
 73:     };
 74: 
 75:     emails.forEach(email => {
 76:       let categorized = false;
 77: 
 78:       if (email.labels.includes(LABEL_KEEP_IMPORTANT)) {
 79:         categories[LABEL_KEEP_IMPORTANT].push(email);
 80:         categorized = true;
 81:       } else if (email.labels.includes(LABEL_EVENTS)) {
 82:         categories[LABEL_EVENTS].push(email);
 83:         categorized = true;
 84:       } else if (email.labels.includes(LABEL_MONITORING)) {
 85:         categories[LABEL_MONITORING].push(email);
 86:         categorized = true;
 87:       } else if (email.labels.includes(LABEL_PRODUCT_UPDATES)) {
 88:         categories[LABEL_PRODUCT_UPDATES].push(email);
 89:         categorized = true;
 90:       } else if (email.labels.includes(LABEL_COMMUNITIES)) {
 91:         categories[LABEL_COMMUNITIES].push(email);
 92:         categorized = true;
 93:       } else if (email.labels.includes(LABEL_SERVICES)) {
 94:         categories[LABEL_SERVICES].push(email);
 95:         categorized = true;
 96:       } else if (email.labels.includes(LABEL_BILLING)) {
 97:         categories[LABEL_BILLING].push(email);
 98:         categorized = true;
 99:       }
100: 
101:       // Fallback: categorize by sender/subject
102:       if (!categorized) {
103:         if (email.from.includes('sentry')) {
104:           categories[LABEL_SENTRY].push(email);
105:         } else {
106:           categories['Other'].push(email);
107:         }
108:       }
109:     });
110: 
111:     // Print categorized results
112:     Object.entries(categories).forEach(([category, items]) => {
113:       if (items.length > 0) {
114:         console.log(`\n${category} (${items.length}):`);
115:         console.log('─'.repeat(80));
116:         items.slice(0, 5).forEach(email => {
117:           const sender = extractDisplayName(email.from);
118:           console.log(`  • ${email.subject.substring(0, 60)}`);
119:           console.log(`    From: ${sender.substring(0, 50)}`);
120:         });
121:         if (items.length > 5) {
122:           console.log(`  ... and ${items.length - 5} more`);
123:         }
124:       }
125:     });
126: 
127:     console.log('\n' + '═'.repeat(80));
128:     console.log('\nSUMMARY\n');
