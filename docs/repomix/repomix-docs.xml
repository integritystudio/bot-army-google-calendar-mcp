 777: #### 3.3 Handle Edge Cases & Timezone Conversion (1.5 hours)
 778: 
 779: Improve timezone handling in SchemaOrgSerializer:
 780: 
 781: ```typescript
 782: // Add to src/services/SchemaOrgSerializer.ts
 783: 
 784: import { parseISO, format, formatISO } from 'date-fns';
 785: import { utcToZonedTime, zonedTimeToUtc } from 'date-fns-tz';
 786: 
 787: export class SchemaOrgSerializer {
 788:   /**
 789:    * Convert timezone-aware datetime to ISO 8601 with UTC offset
 790:    *
 791:    * @param dateTime ISO string like "2026-03-24T10:00:00"
 792:    * @param timeZone IANA timezone like "America/Los_Angeles"
 793:    * @returns ISO 8601 with UTC offset like "2026-03-24T10:00:00-07:00"
 794:    */
 795:   private convertToIso8601WithOffset(dateTime: string, timeZone: string): string {
 796:     try {
 797:       // Parse the dateTime as if it's in the specified timezone
 798:       const zonedDate = utcToZonedTime(parseISO(dateTime), timeZone);
 799: 
 800:       // Convert back to UTC and format with offset
 801:       const utcDate = zonedTimeToUtc(zonedDate, timeZone);
 802: 
 803:       // Format with timezone offset
 804:       return formatISO(utcDate, { representation: 'complete' });
 805:     } catch (error) {
 806:       // Fallback: return as-is if conversion fails
 807:       console.warn(`Timezone conversion failed for ${dateTime} in ${timeZone}:`, error);
 808:       return dateTime;
 809:     }
 810:   }
 811: 
 812:   /**
 813:    * Handle all edge cases in datetime formatting
 814:    */
 815:   private formatDateTime(dt: CalendarEvent['start'] | CalendarEvent['end'] | undefined): string | null {
 816:     if (!dt) return null;
 817: 
 818:     // Case 1: All-day event (date without time)
 819:     if (dt.date && !dt.dateTime) {
 820:       return dt.date; // ISO 8601 date: YYYY-MM-DD
 821:     }
 822: 
 823:     // Case 2: Datetime with timezone
 824:     if (dt.dateTime && dt.timeZone) {
 825:       return this.convertToIso8601WithOffset(dt.dateTime, dt.timeZone);
 826:     }
 827: 
 828:     // Case 3: Datetime without timezone (use UTC)
 829:     if (dt.dateTime && !dt.timeZone) {
 830:       // Assume UTC or local time - return as-is
 831:       return dt.dateTime;
 832:     }
 833: 
 834:     return null;
 835:   }
 836: }
 837: ```
