250: ## 💻 Code Template: SchemaOrgSerializer
251: 
252: Use this as your starting point:
253: 
254: ```typescript
255: // src/services/SchemaOrgSerializer.ts
256: 
257: import { CalendarEvent, CalendarEventAttendee } from '../schemas/types';
258: 
259: export class SchemaOrgSerializer {
260:   serializeEvent(event: CalendarEvent) {
261:     return {
262:       '@context': 'https://schema.org',
263:       '@type': 'Event',
264:       identifier: event.id,
265:       name: event.summary,
266:       startDate: this.formatDateTime(event.start),
267:       endDate: this.formatDateTime(event.end),
268:       location: event.location,
269:       attendee: this.serializeAttendees(event.attendees),
270:     };
271:   }
272: 
273:   private formatDateTime(dt: any): string | null {
274:     if (!dt) return null;
275:     if (dt.date && !dt.dateTime) return dt.date;
276:     // TODO: Handle timezone conversion
277:     return dt.dateTime;
278:   }
279: 
280:   private serializeAttendees(attendees: any[]): any[] {
281:     if (!attendees) return [];
282:     return attendees.map(a => ({
283:       '@type': 'Person',
284:       email: a.email,
285:       name: a.displayName,
286:     }));
287:   }
288: }
289: ```
