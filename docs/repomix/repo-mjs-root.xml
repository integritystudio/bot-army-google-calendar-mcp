31:       )
32:     );
33: 
34:     const pastIds = fullMsgs
35:       .filter(fullMsg => {
36:         const headers = fullMsg.data.payload?.headers || [];
37:         const subject = getHeader(headers, 'Subject');
38: 
39:         let body = '';
40:         if (fullMsg.data.payload?.body?.data) {
41:           body = Buffer.from(fullMsg.data.payload.body.data, 'base64').toString('utf-8');
42:         } else if (fullMsg.data.payload?.parts) {
43:           const textPart = fullMsg.data.payload.parts.find(p => p.mimeType === 'text/plain');
44:           if (textPart?.body?.data) {
45:             body = Buffer.from(textPart.body.data, 'base64').toString('utf-8');
46:           }
47:         }
48: 
49:         const eventDate = extractEventDate(subject + '\n' + body);
50:         return eventDate && isPastEvent(eventDate);
51:       })
52:       .map(fullMsg => fullMsg.data.id);
53: 
54:     console.log(`Identified ${pastIds.length} past events\n`);
55: 
56:     if (pastIds.length === 0) {
57:       console.log('✅ No past events found\n');
