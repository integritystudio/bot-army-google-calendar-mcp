<file path="update-billing-filter.mjs">
  1: import { createGmailClient } from './lib/gmail-client.mjs';
  2: import { USER_ID, LABEL_BILLING, LABEL_KEEP_IMPORTANT } from './lib/constants.mjs';
  3: 
  4: async function updateBillingFilter() {
  5:   const gmail = createGmailClient();
  6: 
  7:   console.log('💳 UPDATING BILLING FILTER - PROTECT URGENT ALERTS\n');
  8:   console.log('═'.repeat(80) + '\n');
  9: 
 10:   try {
 11:     const labelsResponse = await gmail.users.labels.list({ userId: USER_ID });
 12:     const billingLabel = labelsResponse.data.labels.find(l => l.name === LABEL_BILLING);
 13:     const keepImportantLabel = labelsResponse.data.labels.find(l => l.name === LABEL_KEEP_IMPORTANT);
 14: 
 15:     if (!billingLabel) {
 16:       console.log('❌ Billing label not found. Run create-billing-filter.mjs first.\n');
 17:       process.exit(1);
 18:     }
 19: 
 20:     if (!keepImportantLabel) {
 21:       console.log('❌ Keep Important label not found.\n');
 22:       process.exit(1);
 23:     }
 24: 
 25:     const billingLabelId = billingLabel.id;
 26:     const keepImportantLabelId = keepImportantLabel.id;
 27: 
 28:     console.log('STEP 1: Creating urgent billing alert filter\n');
 29: 
 30:     const urgentKeywords = '(late fee OR overdue OR "missed payment")';
 31:     const billingKeywords = '(invoice OR billing OR payment OR charge OR receipt OR statement)';
 32: 
 33:     try {
 34:       await gmail.users.settings.filters.create({
 35:         userId: USER_ID,
 36:         requestBody: {
 37:           criteria: {
 38:             query: `subject:${billingKeywords} subject:${urgentKeywords}`
 39:           },
 40:           action: {
 41:             addLabelIds: [billingLabelId, keepImportantLabelId]
 42:           }
 43:         }
 44:       });
 45:       console.log('✅ Filter created: Urgent billing alerts (KEEP IN INBOX)');
 46:       console.log('   Criteria: Billing keywords + (late fee OR overdue OR missed payment)');
 47:       console.log('   Action: Label Billing + Keep Important\n');
 48:     } catch (error) {
 49:       if (error.message.includes('Too many')) {
 50:         console.log('⚠️  Gmail label limit reached, using simplified approach\n');
 51:       } else {
 52:         throw error;
 53:       }
 54:     }
 55: 
 56:     console.log('STEP 2: Applying to existing urgent billing emails\n');
 57: 
 58:     const urgentQuery = `subject:${billingKeywords} subject:${urgentKeywords}`;
 59:     const urgentResponse = await gmail.users.messages.list({
 60:       userId: USER_ID,
 61:       q: urgentQuery,
 62:       maxResults: 100
 63:     });
 64: 
 65:     const urgentIds = urgentResponse.data.messages || [];
 66:     if (urgentIds.length > 0) {
 67:       const batchSize = 50;
 68:       for (let i = 0; i < urgentIds.length; i += batchSize) {
 69:         const batch = urgentIds.slice(i, i + batchSize);
 70:         await gmail.users.messages.batchModify({
 71:           userId: USER_ID,
 72:           requestBody: {
 73:             ids: batch.map(m => m.id),
 74:             addLabelIds: [billingLabelId, keepImportantLabelId]
 75:           }
 76:         });
 77:       }
 78:       console.log(`  ✅ Applied to ${urgentIds.length} urgent billing emails (kept in inbox)\n`);
 79:     } else {
 80:       console.log('  ℹ️  No urgent billing emails found\n');
 81:     }
 82: 
 83:     console.log('═'.repeat(80));
 84:     console.log('COMPLETE\n');
 85:     console.log('Updated Billing Filter Rules:');
 86:     console.log('  🚨 Urgent Billing → (late fee OR overdue OR missed payment)');
 87:     console.log('     Action: Label Billing + Keep Important → STAY IN INBOX\n');
 88:     console.log('  📌 Rate Limit Alerts → (already protected by Cloudflare filter)');
 89:     console.log('     Action: Keep Important → STAY IN INBOX\n');
 90:     console.log('  💳 Regular Billing → Everything else');
 91:     console.log('     Action: Label Billing → ARCHIVED\n');
 92:     console.log('═'.repeat(80) + '\n');
 93: 
 94:   } catch (error) {
 95:     console.error('❌ Error:', error.message);
 96:     process.exit(1);
 97:   }
 98: }
 99: 
100: updateBillingFilter().catch(error => {
