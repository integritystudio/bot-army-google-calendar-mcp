 23:     const cred = credFile.installed || credFile;
 24: 
 25:     const oauth2Client = new OAuth2Client(
 26:       cred.client_id,
 27:       cred.client_secret,
 28:       'http://localhost:3500/oauth2callback'
 29:     );
 30: 
 31:     const authUrl = oauth2Client.generateAuthUrl({
 32:       access_type: 'offline',
 33:       scope: GMAIL_SCOPES
 34:     });
 35: 
 36:     console.log('Opening browser for Gmail authentication...');
 37:     console.log('Auth URL:', authUrl);
 38: 
 39:     const server = createServer(async (req, res) => {
 40:       const urlObj = new URL(req.url, 'http://localhost:3500');
 41:       const code = urlObj.searchParams.get('code');
 42: 
 43:       if (!code) {
 44:         res.writeHead(400);
 45:         res.end('No authorization code received');
 46:         return;
 47:       }
 48: 
 49:       try {
 50:         const { tokens } = await oauth2Client.getToken(code);
 51:         oauth2Client.setCredentials(tokens);
