10:   try {
11:     const labelsResponse = await gmail.users.labels.list({ userId: USER_ID });
12:     const labels = labelsResponse.data.labels || [];
13:     const labelMap = {};
14:     labels.forEach(l => { labelMap[l.id] = l.name; });
15: 
16:     const allUnreadResponse = await gmail.users.messages.list({
17:       userId: USER_ID,
18:       q: 'is:unread',
19:       maxResults: 500
20:     });
21: 
22:     const allUnread = allUnreadResponse.data.messages || [];
23:     console.log(`Total unread: ${allUnread.length}\n`);
24: 
25:     const chunkSize = 50;
26:     const fullMsgs = [];
27:     for (let i = 0; i < allUnread.length; i += chunkSize) {
28:       const chunk = await Promise.all(
29:         allUnread.slice(i, i + chunkSize).map(msg =>
30:           gmail.users.messages.get({ userId: USER_ID, id: msg.id })
31:         )
32:       );
33:       fullMsgs.push(...chunk);
34:     }
35: 
36:     const categories = {};
37: 
38:     for (const fullMsg of fullMsgs) {
39:       const msgLabels = (fullMsg.data.labelIds || []).map(id => labelMap[id]).filter(Boolean);
40:       const labelStr = msgLabels.length > 0 ? msgLabels.join(', ') : 'No labels';
41: 
42:       if (!categories[labelStr]) {
43:         categories[labelStr] = [];
44:       }
45:       categories[labelStr].push(fullMsg.data.id);
46:     }
47: 
48:     Object.entries(categories)
49:       .sort((a, b) => b[1].length - a[1].length)
50:       .forEach(([labels, ids]) => {
51:         console.log(`${labels}: ${ids.length}`);
52:       });
53: 
54:     console.log('\n' + '═'.repeat(80));
55:     console.log(`\nBreakdown shows which labels most unread emails have.`);
56:     console.log(`Items with "No labels" are the best candidates for new filters.\n`);
57:     console.log('═'.repeat(80) + '\n');
58: 
59:   } catch (error) {
60:     console.error('Error:', error.message);
61:     process.exit(1);
62:   }
63: }
64: 
65: analyzeUnread().catch(error => {
