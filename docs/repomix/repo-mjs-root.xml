124:   const categories = [
125:     { key: 'highUrgencyHighImportance', icon: '🔴', label: 'HIGH URGENCY + HIGH IMPORTANCE (ACT NOW!)' },
126:     { key: 'highUrgencyMediumImportance', icon: '🟠', label: 'HIGH URGENCY + MEDIUM IMPORTANCE (SOON)' },
127:     { key: 'highUrgencyLowImportance', icon: '🟡', label: 'HIGH URGENCY + LOW IMPORTANCE (QUICK)' },
128:     { key: 'mediumUrgencyHighImportance', icon: '🔵', label: 'MEDIUM URGENCY + HIGH IMPORTANCE (IMPORTANT)' },
129:     { key: 'mediumUrgencyMediumImportance', icon: '⚪', label: 'MEDIUM URGENCY + MEDIUM IMPORTANCE (NORMAL)' },
130:     { key: 'mediumUrgencyLowImportance', icon: '⚪', label: 'MEDIUM URGENCY + LOW IMPORTANCE (CAN WAIT)' },
131:     { key: 'lowUrgencyHighImportance', icon: '💙', label: 'LOW URGENCY + HIGH IMPORTANCE (READ LATER)' },
132:     { key: 'lowUrgencyMediumImportance', icon: '⚪', label: 'LOW URGENCY + MEDIUM IMPORTANCE (BACKGROUND)' },
133:     { key: 'lowUrgencyLowImportance', icon: '⚪', label: 'LOW URGENCY + LOW IMPORTANCE (ARCHIVE?)' }
134:   ];
135: 
136:   let totalProcessed = 0;
137: 
138:   categories.forEach(category => {
139:     const emails = categorized[category.key] || [];
