 92:         const batch = futureIds.slice(i, i + batchSize);
 93:         await gmail.users.messages.batchModify({
 94:           userId: USER_ID,
 95:           requestBody: {
 96:             ids: batch,
 97:             addLabelIds: [eventsLabelId]
 98:           }
 99:         });
100:         const processed = i + batch.length;
101:         console.log(`  ✅ Labeled ${processed}/${futureIds.length}`);
102:       }
103:     }
104: 
105:     if (pastIds.length > 0) {
