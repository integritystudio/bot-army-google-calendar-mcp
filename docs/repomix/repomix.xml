  describe('Edge Cases and Additional Scenarios', () => {
    it('should handle events with complex recurrence patterns', async () => {
      const complexRecurringEvent = {
        data: {
          id: 'complex123',
          summary: 'Complex Meeting',
          start: { dateTime: '2024-06-01T10:00:00Z' },
