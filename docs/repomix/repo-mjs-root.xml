<file path="archive-old-meeting-responses.mjs">
 1: import { createGmailClient } from './lib/gmail-client.mjs';
 2: import { USER_ID, GMAIL_INBOX, GMAIL_UNREAD } from './lib/constants.mjs';
 3: import { getHeader } from './lib/email-utils.mjs';
 4: 
 5: const gmail = createGmailClient();
 6: 
 7: console.log('📅 ARCHIVING OLD MEETING RESPONSES\n');
 8: console.log('═'.repeat(80) + '\n');
 9: 
10: const today = new Date();
11: const oneWeekAgo = new Date(today.getTime() - 7 * 24 * 60 * 60 * 1000);
12: const dateStr = oneWeekAgo.toISOString().split('T')[0];
13: 
14: console.log(`Archiving responses before ${dateStr}\n`);
15: 
16: const searchQueries = [
17:   'subject:Accepted subject:Integrity',
18:   'subject:Declined subject:Integrity',
19:   'subject:"Added to a team"',
20:   'from:john@integritystudio.ai subject:(Accepted OR Declined)',
21:   'from:chandra@integritystudio.ai subject:(Accepted OR Declined)'
22: ];
23: 
24: let totalArchived = 0;
25: 
26: for (const query of searchQueries) {
27:   const searchResp = await gmail.users.messages.list({
28:     userId: USER_ID,
29:     q: query,
30:     maxResults: 100
31:   });
32: 
33:   const messages = searchResp.data.messages || [];
34:   if (messages.length === 0) continue;
35: 
36:   console.log(`Query: ${query}`);
37:   console.log(`Found ${messages.length} emails\n`);
38: 
39:   const fullMsgs = await Promise.all(
40:     messages.map(msg =>
41:       gmail.users.messages.get({
42:         userId: USER_ID,
43:         id: msg.id,
44:         format: 'metadata',
45:         metadataHeaders: ['Date', 'Subject']
46:       })
47:     )
48:   );
49: 
50:   const oldIds = [];
51: 
52:   for (const fullMsg of fullMsgs) {
53:     const headers = fullMsg.data.payload?.headers || [];
