{
  "include": [
    "*.mjs",
    "src/tools/registry.ts",
    "src/schemas/**",
    "src/utils/**",
    "lib/**"
  ],
  "output": {
    "filePath": "docs/repomix/repo-compact.xml",
    "style": "xml",
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": true,
    "topFilesLength": 10,
    "copyToClipboard": false
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "docs/**",
      "examples/**",
      "*.tsbuildinfo",
      ".env.*.local",
      ".cache/**",
      "**/README.md",
      "instructions/**",
      ".claude/settings.local.json",
      "AGENTS.md",
      "CLAUDE.md"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
