        timeMax: undefined,
        singleEvents: true,
        orderBy: 'startTime'
      });

      // Should return text content with events
      expect(result.content).toHaveLength(1);
      expect(result.content[0].type).toBe('text');
      expect(getTextContent(result)).toContain('Found');
    });
  });
});
