118:     let categorized = false;
119:     for (const [category, pattern] of Object.entries(categoryPatterns)) {
120:       if (pattern.test(msg.subject)) {
121:         categories[category]++;
122:         categorized = true;
123:         break;
124:       }
125:     }
126:     if (!categorized) {
127:       categories['Other']++;
128:     }
