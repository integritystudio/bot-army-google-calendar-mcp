<file path="analyze_emails.mjs">
  1: import { createGmailClient } from './lib/gmail-client.mjs';
  2: import { extractDisplayName, getHeader } from './lib/email-utils.mjs';
  3: import { USER_ID } from './lib/constants.mjs';
  4: import { categorizeEmail, printSection, ANALYZER_CONFIG } from './lib/email-analyzer.mjs';
  5: 
  6: const FROM_MAX = 45;
  7: const SUBJECT_MAX = 60;
  8: const SNIPPET_MAX = 65;
  9: const MAX_RESULTS = 100;
 10: 
 11: const { SECTION_DIVIDER } = ANALYZER_CONFIG;
 12: 
 13: async function analyzeUnreadEmails() {
 14:   try {
 15:     const gmail = createGmailClient();
 16: 
 17:     const response = await gmail.users.messages.list({
 18:       userId: USER_ID,
 19:       q: "is:unread",
 20:       maxResults: MAX_RESULTS
 21:     });
 22: 
 23:     const messageIds = response.data.messages || [];
 24:     console.log(`\n📧 FOUND ${messageIds.length} UNREAD MESSAGES\n`);
 25: 
 26:     const headers = ['Subject', 'From'];
 27:     const messages = await Promise.all(
 28:       messageIds.map(async (msg) => {
 29:         try {
 30:           const fullMsg = await gmail.users.messages.get({
 31:             userId: USER_ID,
 32:             id: msg.id,
 33:             format: "metadata",
 34:             metadataHeaders: headers
 35:           });
 36: 
 37:           const headerList = fullMsg.data.payload?.headers || [];
 38: 
 39:           return {
 40:             id: msg.id,
 41:             subject: getHeader(headerList, 'Subject') || "(No subject)",
 42:             from: extractDisplayName(getHeader(headerList, 'From')) || "(Unknown sender)",
 43:             snippet: fullMsg.data.snippet || ""
 44:           };
 45:         } catch (error) {
 46:           console.warn(`Failed to fetch message ${msg.id}: ${error.message}`);
 47:           return null;
 48:         }
 49:       })
 50:     );
 51: 
 52:     const validMessages = messages.filter(Boolean);
 53: 
 54:     const matrix = {
 55:       'HighHigh': [], 'HighMedium': [], 'HighLow': [],
 56:       'MediumHigh': [], 'MediumMedium': [], 'MediumLow': [],
 57:       'LowHigh': [], 'LowMedium': [], 'LowLow': []
 58:     };
 59: 
 60:     validMessages.forEach(msg => {
 61:       const { urgency, importance } = categorizeEmail(msg);
 62:       const key = `${urgency}${importance}`;
 63:       matrix[key].push(msg);
 64:     });
 65: 
 66:     console.log("╔════════════════════════════════════════════════════════════════════════════════╗");
 67:     console.log("║            UNREAD EMAIL MATRIX: URGENCY (rows) × IMPORTANCE (cols)            ║");
 68:     console.log("╚════════════════════════════════════════════════════════════════════════════════╝\n");
 69: 
 70:     const displayConfig = { fromMax: FROM_MAX, subjectMax: SUBJECT_MAX, snippetMax: SNIPPET_MAX };
 71: 
 72:     printSection('🔴 HIGH URGENCY EMAILS (ACT IMMEDIATELY!)', [
 73:       { label: '⚠️  HIGH IMPORTANCE - CRITICAL (DO THIS NOW!)', emails: matrix.HighHigh },
 74:       { label: '⚡ MEDIUM IMPORTANCE - IMPORTANT (HANDLE SOON)', emails: matrix.HighMedium },
 75:       { label: '💨 LOW IMPORTANCE - QUICK ATTENTION (BRIEF)', emails: matrix.HighLow }
 76:     ], displayConfig);
 77: 
 78:     printSection('🟠 MEDIUM URGENCY EMAILS (ADDRESS TODAY)', [
 79:       { label: '💼 HIGH IMPORTANCE - IMPORTANT (PRIORITIZE)', emails: matrix.MediumHigh },
 80:       { label: '📧 MEDIUM IMPORTANCE - STANDARD (ROUTINE)', emails: matrix.MediumMedium },
 81:       { label: '⏳ LOW IMPORTANCE - NOT URGENT (BACKLOG)', emails: matrix.MediumLow }
 82:     ], displayConfig);
 83: 
 84:     printSection('🟡 LOW URGENCY EMAILS (READ WHEN YOU HAVE TIME)', [
 85:       { label: '📚 HIGH IMPORTANCE - READ LATER (VALUABLE)', emails: matrix.LowHigh },
 86:       { label: '📰 MEDIUM IMPORTANCE - FYI (INFORMATIONAL)', emails: matrix.LowMedium, limit: 5 },
 87:       { label: '🗑️  LOW IMPORTANCE - ARCHIVE? (PROMOTIONAL)', emails: matrix.LowLow, count: true }
 88:     ], displayConfig);
 89: 
 90:     console.log("\n" + SECTION_DIVIDER);
 91:     console.log("ACTIONABLE SUMMARY");
 92:     console.log(SECTION_DIVIDER + "\n");
 93: 
 94:     const stats = {
 95:       critical: matrix.HighHigh.length,
 96:       important: matrix.HighMedium.length + matrix.MediumHigh.length,
 97:       routine: matrix.HighLow.length + matrix.MediumMedium.length,
 98:       backlog: matrix.MediumLow.length + matrix.LowHigh.length + matrix.LowMedium.length,
 99:       archive: matrix.LowLow.length
100:     };
101: 
102:     console.log(`🔴 CRITICAL (Act Now):           ${stats.critical} emails`);
103:     console.log(`🟠 IMPORTANT (Today):            ${stats.important} emails`);
104:     console.log(`🟡 ROUTINE (This week):          ${stats.routine} emails`);
105:     console.log(`🟢 BACKLOG (Eventually):         ${stats.backlog} emails`);
106:     console.log(`⚫ ARCHIVE CANDIDATES:           ${stats.archive} emails`);
107:     console.log(`\n📊 Total Unread:                 ${validMessages.length} emails\n`);
108: 
109:   } catch (error) {
110:     console.error('Error:', error instanceof Error ? error.message : error);
111:     process.exit(1);
112:   }
113: }
114: 
115: analyzeUnreadEmails().catch(error => {
116:   console.error('❌ Error:', error.message);
117:   process.exit(1);
118: });
