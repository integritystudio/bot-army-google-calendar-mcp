GIT_RANKED_REPO_FILE="$OUT_DIR/$GIT_RANKED_FILE.xml"
GITLOG_TOP_FILE="$OUT_DIR/gitlog-top20.txt"
TREE_FILE_NAME="$OUTPUT_PATH/$TREE_FILE.txt"
