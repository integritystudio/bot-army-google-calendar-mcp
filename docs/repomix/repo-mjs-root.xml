 9:   console.log('📅 MARKING PAST EVENTS AS READ\n');
10:   console.log('═'.repeat(80) + '\n');
11: 
12:   try {
13:     const searchQuery = `label:${LABEL_EVENTS} is:unread`;
14:     const searchResponse = await gmail.users.messages.list({
15:       userId: USER_ID,
16:       q: searchQuery,
17:       maxResults: 500
18:     });
19: 
20:     const messageIds = searchResponse.data.messages || [];
21:     console.log(`Found ${messageIds.length} unread event emails\n`);
22: 
23:     if (messageIds.length === 0) {
24:       console.log('✅ No unread events to process\n');
25:       return;
