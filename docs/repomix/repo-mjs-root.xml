<file path="protect-important-inbox.mjs">
  1: import { createGmailClient } from './lib/gmail-client.mjs';
  2: import { USER_ID, LABEL_KEEP_IMPORTANT } from './lib/constants.mjs';
  3: 
  4: async function protectImportantItems() {
  5:   const gmail = createGmailClient();
  6: 
  7:   console.log('⭐ PROTECTING IMPORTANT ITEMS IN INBOX\n');
  8:   console.log('═'.repeat(80) + '\n');
  9: 
 10:   let importantLabelId;
 11:   const labelsResponse = await gmail.users.labels.list({ userId: USER_ID });
 12:   const existingLabel = labelsResponse.data.labels.find(l => l.name === LABEL_KEEP_IMPORTANT);
 13: 
 14:   if (existingLabel) {
 15:     importantLabelId = existingLabel.id;
 16:     console.log('✅ Using existing label: Keep Important\n');
 17:   } else {
 18:     const createLabelResponse = await gmail.users.labels.create({
 19:       userId: USER_ID,
 20:       requestBody: {
 21:         name: LABEL_KEEP_IMPORTANT,
 22:         labelListVisibility: 'labelShow',
 23:         messageListVisibility: 'show'
 24:       }
 25:     });
 26:     importantLabelId = createLabelResponse.data.id;
 27:     console.log('✅ Created label: Keep Important\n');
 28:   }
 29: 
 30:   const importantFilters = [
 31:     {
 32:       name: 'Cloudflare Alerts',
 33:       query: 'from:noreply@notify.cloudflare.com'
 34:     },
 35:     {
 36:       name: 'Calendly Refunds & Support',
 37:       query: 'from:(support@calendly.zendesk.com OR invoice+statements@calendly.com) OR subject:(refund OR "Added to a team")'
 38:     },
 39:     {
 40:       name: 'Investment Banking Meetings',
 41:       query: 'from:notification@calendly.com subject:"Introductory Meeting"'
 42:     },
 43:     {
 44:       name: 'Capital City Village Services',
 45:       query: 'from:(capitalcity@a.helpfulvillage.com OR info@capitalcityvillage.org)'
 46:     }
 47:   ];
 48: 
 49:   console.log('STEP 1: Creating filters to keep important items in inbox\n');
 50: 
 51:   for (const config of importantFilters) {
 52:     try {
 53:       await gmail.users.settings.filters.create({
 54:         userId: USER_ID,
 55:         requestBody: {
 56:           criteria: {
 57:             query: config.query
 58:           },
 59:           action: {
 60:             addLabelIds: [importantLabelId]
 61:             // Note: NOT removing INBOX label - this keeps them visible
 62:           }
 63:         }
 64:       });
 65:       console.log(`  ✅ ${config.name}`);
 66:       console.log(`     Query: ${config.query}\n`);
 67:     } catch (error) {
 68:       console.log(`  ⚠️  ${config.name}: ${error.message}\n`);
 69:     }
 70:   }
 71: 
 72:   console.log('STEP 2: Labeling existing important emails\n');
 73: 
 74:   const queryCounts = await Promise.all(
 75:     importantFilters.map(async ({ query }) => {
 76:       const searchResponse = await gmail.users.messages.list({
 77:         userId: USER_ID,
 78:         q: query,
 79:         maxResults: 100
 80:       });
 81: 
 82:       const messageIds = searchResponse.data.messages || [];
 83:       if (messageIds.length === 0) return 0;
 84: 
 85:       const batchSize = 50;
 86:       for (let i = 0; i < messageIds.length; i += batchSize) {
 87:         const batch = messageIds.slice(i, i + batchSize);
 88:         await gmail.users.messages.batchModify({
 89:           userId: USER_ID,
 90:           requestBody: {
 91:             ids: batch.map(m => m.id),
 92:             addLabelIds: [importantLabelId]
 93:           }
 94:         });
 95:       }
 96: 
 97:       return messageIds.length;
 98:     })
 99:   );
100: 
101:   const totalLabeled = queryCounts.reduce((sum, n) => sum + n, 0);
102: 
103:   console.log(`  ✅ Labeled ${totalLabeled} important emails\n`);
104: 
105:   console.log('═'.repeat(80));
106:   console.log('COMPLETE\n');
107:   console.log('Protected items (will stay in inbox):');
108:   console.log('  • Cloudflare alerts (action required)');
109:   console.log('  • Calendly refunds & support');
110:   console.log('  • Investment Banking meeting reminders');
111:   console.log('  • Capital City Village service requests\n');
112:   console.log('All labeled with: Keep Important ⭐\n');
113:   console.log('═'.repeat(80) + '\n');
114: }
115: 
116: protectImportantItems().catch(error => {
117:   console.error('❌ Error:', error.message);
118:   process.exit(1);
119: });
</file>

