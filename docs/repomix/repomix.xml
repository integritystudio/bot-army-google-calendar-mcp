echo ""
echo "Recent commits:"
git log --oneline -5

echo ""
echo "✓ Rollback preparation complete"
echo ""
echo "Next steps:"
echo "1. Verify PM2 processes: pm2 status"
echo "2. Check logs: pm2 logs aleph-dashboard"
