121:     "description": "The end date and time of the item (in ISO 8601 date format).",
122:     "types": ["DateTime", "Date"],
123:     "required": false
124:   },
125:   {
126:     "name": "location",
127:     "description": "The location of the event, organization or action.",
128:     "types": ["Place", "Text"],
