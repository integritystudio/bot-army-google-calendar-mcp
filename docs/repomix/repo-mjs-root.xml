<file path="revert-google-workspace-labels.mjs">
 1: import { createGmailClient } from './lib/gmail-client.mjs';
 2: import { USER_ID, LABEL_UPDATES, LABEL_ORG_GOOGLE_WORKSPACE } from './lib/constants.mjs';
 3: 
 4: async function revertGoogleWorkspaceLabels() {
 5:   const gmail = createGmailClient();
 6: 
 7:   console.log('⏮️  REVERTING GOOGLE WORKSPACE LABELS\n');
 8:   console.log('═'.repeat(80) + '\n');
 9: 
10:   try {
11:     const labelsResponse = await gmail.users.labels.list({ userId: USER_ID });
12:     const updatesLabel = labelsResponse.data.labels.find(l => l.name === LABEL_UPDATES);
13:     const orgLabel = labelsResponse.data.labels.find(l => l.name === LABEL_ORG_GOOGLE_WORKSPACE);
14: 
15:     if (!updatesLabel && !orgLabel) {
16:       console.log('No labels to remove\n');
17:       return;
18:     }
19: 
20:     console.log('STEP 1: Finding labeled Google Workspace emails\n');
21: 
22:     const labelIds = [];
23:     if (updatesLabel) labelIds.push(`label:${updatesLabel.id}`);
24:     if (orgLabel) labelIds.push(`label:${orgLabel.id}`);
25: 
26:     const searchQuery = labelIds.join(' OR ');
27:     const searchResponse = await gmail.users.messages.list({
28:       userId: USER_ID,
29:       q: searchQuery,
30:       maxResults: 100
31:     });
32: 
33:     const messageIds = searchResponse.data.messages || [];
34:     console.log(`Found ${messageIds.length} emails with these labels\n`);
35: 
36:     if (messageIds.length > 0) {
37:       console.log('STEP 2: Removing labels\n');
38: 
39:       const removeLabelIds = [];
40:       if (updatesLabel) removeLabelIds.push(updatesLabel.id);
41:       if (orgLabel) removeLabelIds.push(orgLabel.id);
42: 
43:       const batchSize = 50;
44:       for (let i = 0; i < messageIds.length; i += batchSize) {
45:         const batch = messageIds.slice(i, i + batchSize);
46: 
47:         await gmail.users.messages.batchModify({
48:           userId: USER_ID,
49:           requestBody: {
50:             ids: batch.map(m => m.id),
51:             removeLabelIds: removeLabelIds
52:           }
53:         });
54: 
55:         const processed = i + batch.length;
56:         console.log(`  ✅ Removed from ${processed}/${messageIds.length}`);
57:       }
58:     }
59: 
60:     console.log('\n' + '═'.repeat(80));
61:     console.log('COMPLETE\n');
62:     console.log(`✅ Reverted: ${messageIds.length} emails`);
63:     if (updatesLabel) console.log(`✅ Removed label: Updates`);
64:     if (orgLabel) console.log(`✅ Removed label: Organization: Google Workspace`);
65:     console.log('\n');
66:     console.log('Note: Labels still exist but are no longer applied to emails\n');
67:     console.log('═'.repeat(80) + '\n');
68: 
69:   } catch (error) {
70:     console.error('❌ Error:', error.message);
71:     process.exit(1);
72:   }
73: }
74: 
75: revertGoogleWorkspaceLabels().catch(error => {
76:   console.error('❌ Error:', error.message);
77:   process.exit(1);
78: });
</file>

