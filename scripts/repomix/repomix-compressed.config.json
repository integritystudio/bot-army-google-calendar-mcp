{
  "output": {
    "filePath": "docs/repomix/repo-compressed.xml",
    "style": "xml",
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": true,
    "topFilesLength": 10,
    "copyToClipboard": false
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "docs/**",
      "scripts/repomix/*.sh",
      "*.tsbuildinfo",
      ".env.*.local",
      ".cache/**",
      "**/README.md",
      "instructions/**"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
