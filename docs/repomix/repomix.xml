    console.log(`🟡 ROUTINE (This week):          ${stats.routine} emails`);
    console.log(`🟢 BACKLOG (Eventually):         ${stats.backlog} emails`);
    console.log(`⚫ ARCHIVE CANDIDATES:           ${stats.archive} emails`);
