55:     const subject = getHeader(headers, 'Subject');
56:     const emailDate = new Date(msgDateStr);
57: 
58:     if (emailDate < oneWeekAgo) {
59:       oldIds.push(fullMsg.data.id);
60:       console.log(`  ✓ ${subject.substring(0, 50)}`);
61:       console.log(`    Date: ${emailDate.toLocaleDateString()}\n`);
