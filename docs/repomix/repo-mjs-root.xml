 20:     'from:news@alphasignal.ai',
 21:     'from:noreply@email.openai.com',
 22:     'from:hello@adapty.io',
 23:     'from:info@email.meetup.com',
 24:     'from:googlecloud@google.com',
 25:     'from:communications@yodlee.com',
 26:     'from:updates-noreply@linkedin.com',
