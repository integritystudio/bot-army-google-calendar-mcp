 99:     'Community News': 0,
100:     'Career/Jobs': 0,
101:     'Tech/Innovation': 0,
102:     'Events': 0,
103:     'Reports/Analysis': 0,
104:     'Other': 0,
105:   };
106: 
107:   const categoryPatterns = {
108:     'Funding/Startup News': /fund|startup|funding|investment|investor|raise|series|valuation/i,
109:     'Industry Updates': /industry|market|trend|analysis|report/i,
110:     'Community News': /community|event|conference|meetup|gather/i,
111:     'Career/Jobs': /job|career|hiring|recruit|opportunity|position/i,
112:     'Tech/Innovation': /tech|ai|innovation|software|platform|tool/i,
113:     'Events': /event|summit|workshop|webinar|conference/i,
114:     'Reports/Analysis': /report|analysis|insight|data|survey|study/i,
115:   };
116: 
