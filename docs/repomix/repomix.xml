      expect(result.start).toEqual({ dateTime: '2024-06-15T10:00:00Z' });
      expect(result.end).toEqual({ dateTime: '2024-06-15T11:00:00Z' });
    });

    it('should not modify original event object', () => {
      const originalEvent: calendar_v3.Schema$Event = {
