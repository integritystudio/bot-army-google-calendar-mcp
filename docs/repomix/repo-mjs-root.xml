 29:     { subject: 'Strategies for Validating World Models', labelId: labelCache.get(LABEL_EVENTS_COMMUNITY_LEARNING_EDUCATION) },
 30:     { subject: 'Intuitive Numerology', labelId: labelCache.get(LABEL_EVENTS_COMMUNITY_SPIRITUAL_WELLNESS) },
 31:   ];
