<file path="organize-international-house.mjs">
  1: import { createGmailClient } from './lib/gmail-client.mjs';
  2: import { USER_ID, GMAIL_INBOX, LABEL_EVENTS } from './lib/constants.mjs';
  3: import { getHeader } from './lib/email-utils.mjs';
  4: 
  5: async function organizeInternationalHouse() {
  6:   const gmail = createGmailClient();
  7: 
  8:   console.log('🎤 ORGANIZING INTERNATIONAL HOUSE EVENTS\n');
  9:   console.log('═'.repeat(80) + '\n');
 10: 
 11:   try {
 12:     let eventsLabelId;
 13:     const labelsResponse = await gmail.users.labels.list({ userId: USER_ID });
 14:     const existingLabel = labelsResponse.data.labels.find(l => l.name === LABEL_EVENTS);
 15: 
 16:     if (existingLabel) {
 17:       eventsLabelId = existingLabel.id;
 18:       console.log('✅ Using existing label: Events\n');
 19:     } else {
 20:       const createLabelResponse = await gmail.users.labels.create({
 21:         userId: USER_ID,
 22:         requestBody: {
 23:           name: LABEL_EVENTS,
 24:           labelListVisibility: 'labelShow',
 25:           messageListVisibility: 'show'
 26:         }
 27:       });
 28:       eventsLabelId = createLabelResponse.data.id;
 29:       console.log('✅ Created label: Events\n');
 30:     }
 31: 
 32:     const searchResponse = await gmail.users.messages.list({
 33:       userId: USER_ID,
 34:       q: 'from:"International House"',
 35:       maxResults: 100
 36:     });
 37: 
 38:     const messageIds = searchResponse.data.messages || [];
 39:     console.log(`Found ${messageIds.length} International House emails\n`);
 40: 
 41:     if (messageIds.length === 0) {
 42:       console.log('No International House emails found\n');
 43:       return;
 44:     }
 45: 
 46:     const today = new Date();
 47:     today.setHours(0, 0, 0, 0);
 48: 
 49:     console.log('Analyzing event dates...\n');
 50: 
 51:     const MONTH_INDEX = { jan: 0, feb: 1, mar: 2, apr: 3, may: 4, jun: 5, jul: 6, aug: 7, sep: 8, oct: 9, nov: 10, dec: 11 };
 52:     const DATE_PATTERN = /(?:@\s+)?(?:Mon|Tue|Wed|Thu|Fri|Sat|Sun),?\s+([A-Za-z]+)\s+(\d{1,2})/i;
 53: 
 54:     const fullMsgs = await Promise.all(
 55:       messageIds.map(msg =>
 56:         gmail.users.messages.get({ userId: USER_ID, id: msg.id, format: 'full' })
 57:           .catch(error => {
 58:             console.log(`⚠️  Error processing email: ${error.message}`);
 59:             return null;
 60:           })
 61:       )
 62:     );
 63: 
 64:     const futureEvents = [];
 65:     const pastEvents = [];
 66: 
 67:     for (const fullMsg of fullMsgs.filter(Boolean)) {
 68:       const headers = fullMsg.data.payload?.headers || [];
 69:       const subject = getHeader(headers, 'Subject');
 70: 
 71:       const body = fullMsg.data.payload?.parts?.[0]?.body?.data
 72:         ? Buffer.from(fullMsg.data.payload.parts[0].body.data, 'base64').toString('utf-8')
 73:         : '';
 74: 
 75:       const match = body.match(DATE_PATTERN) || subject.match(DATE_PATTERN);
 76: 
 77:       let eventDate = null;
 78:       if (match) {
 79:         const monthIndex = MONTH_INDEX[match[1].toLowerCase().substring(0, 3)];
 80:         if (monthIndex !== undefined) {
 81:           eventDate = new Date(today.getFullYear(), monthIndex, parseInt(match[2]));
 82:         }
 83:       }
 84: 
 85:       const entry = { id: fullMsg.data.id, subject, eventDate };
 86:       if (eventDate && eventDate < today) {
 87:         pastEvents.push(entry);
 88:       } else {
 89:         futureEvents.push(entry);
 90:       }
 91:     }
 92: 
 93:     console.log(`Future events: ${futureEvents.length}`);
 94:     console.log(`Past events: ${pastEvents.length}\n`);
 95: 
 96:     if (futureEvents.length > 0) {
 97:       console.log('Labeling future events with "Events"...\n');
 98:       const batchSize = 50;
 99:       for (let i = 0; i < futureEvents.length; i += batchSize) {
100:         const batch = futureEvents.slice(i, i + batchSize);
101:         await gmail.users.messages.batchModify({
102:           userId: USER_ID,
103:           requestBody: {
104:             ids: batch.map(e => e.id),
105:             addLabelIds: [eventsLabelId]
106:           }
107:         });
108:         const processed = i + batch.length;
109:         console.log(`  ✅ Labeled ${processed}/${futureEvents.length}`);
110:       }
111:     }
112: 
113:     if (pastEvents.length > 0) {
114:       console.log('\nArchiving past events...\n');
115:       const batchSize = 50;
116:       for (let i = 0; i < pastEvents.length; i += batchSize) {
117:         const batch = pastEvents.slice(i, i + batchSize);
118:         await gmail.users.messages.batchModify({
119:           userId: USER_ID,
120:           requestBody: {
121:             ids: batch.map(e => e.id),
122:             addLabelIds: [eventsLabelId],
123:             removeLabelIds: [GMAIL_INBOX]
124:           }
125:         });
126:         const processed = i + batch.length;
127:         console.log(`  ✅ Archived ${processed}/${pastEvents.length}`);
128:       }
129:     }
130: 
131:     console.log('\n' + '═'.repeat(80));
132:     console.log('COMPLETE\n');
133:     console.log(`✅ Label: Events`);
134:     console.log(`✅ Future events (staying in inbox): ${futureEvents.length}`);
135:     console.log(`✅ Past events (archived): ${pastEvents.length}\n`);
136:     console.log('═'.repeat(80) + '\n');
137: 
138:   } catch (error) {
139:     console.error('❌ Error:', error.message);
140:     process.exit(1);
141:   }
142: }
143: 
144: organizeInternationalHouse().catch(error => {
145:   console.error('❌ Error:', error.message);
146:   process.exit(1);
147: });
</file>

