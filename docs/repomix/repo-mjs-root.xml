 1: #!/usr/bin/env node
 2: import { initializeOAuth2Client } from './src/auth/client.js';
 3: import { TokenManager } from './src/auth/tokenManager.js';
 4: import fs from 'fs/promises';
 5: import path from 'path';
 6: import { fileURLToPath } from 'url';
 7: 
 8: // Point to credentials.json at root
 9: const __dirname = path.dirname(fileURLToPath(import.meta.url));
10: process.env.GOOGLE_OAUTH_CREDENTIALS = path.join(__dirname, 'credentials.json');
11: 
12: async function verifyAndRefreshTokens() {
13:   try {
14:     console.log('🔍 Verifying OAuth tokens...\n');
15: 
16:     const oauth2Client = await initializeOAuth2Client();
17:     const tokenManager = new TokenManager(oauth2Client);
18:     const tokenPath = tokenManager.getTokenPath();
19: 
20:     console.log(`📁 Token file: ${tokenPath}`);
21:     try {
22:       await fs.access(tokenPath);
23:       console.log('✓ Token file exists\n');
24:     } catch {
25:       console.log('✗ Token file not found. Run: npm run auth\n');
26:       process.exit(1);
27:     }
28: 
29:     const tokenContent = await fs.readFile(tokenPath, 'utf-8');
30:     const tokens = JSON.parse(tokenContent);
31: 
32:     console.log('📋 Available accounts:');
33:     Object.keys(tokens).forEach(account => {
34:       const accountTokens = tokens[account];
35:       const hasRefresh = !!accountTokens.refresh_token;
36:       const hasAccess = !!accountTokens.access_token;
37:       const expiryDate = accountTokens.expiry_date
38:         ? new Date(accountTokens.expiry_date).toLocaleString()
39:         : 'unknown';
40: 
41:       console.log(`  • ${account}`);
42:       console.log(`    - Access token: ${hasAccess ? '✓ present' : '✗ missing'}`);
43:       console.log(`    - Refresh token: ${hasRefresh ? '✓ present' : '✗ missing'}`);
44:       console.log(`    - Expires: ${expiryDate}`);
45:     });
46: 
47:     console.log('\n⏱️  Checking token validity...');
48: 
49:     // Validate and refresh if needed
50:     const isValid = await tokenManager.validateTokens();
51: 
52:     if (isValid) {
53:       console.log('✓ Tokens are valid\n');
54: 
55:       const credentials = oauth2Client.credentials;
56:       if (credentials.expiry_date) {
57:         const expiresIn = Math.floor((credentials.expiry_date - Date.now()) / 1000);
58:         const hours = Math.floor(expiresIn / 3600);
59:         const minutes = Math.floor((expiresIn % 3600) / 60);
60:         console.log(`⏰ Current access token expires in: ${hours}h ${minutes}m`);
61:       }
62:       console.log('✓ Ready to use Google Calendar API');
63:     } else {
64:       console.log('✗ Tokens invalid or expired');
65:       console.log('💡 Run: npm run auth');
66:       process.exit(1);
67:     }
68: 
69:   } catch (error) {
70:     console.error('❌ Error verifying tokens:');
71:     if (error instanceof Error) {
72:       console.error(`   ${error.message}`);
73:     } else {
74:       console.error(`   ${error}`);
75:     }
76:     process.exit(1);
77:   }
78: }
79: 
80: verifyAndRefreshTokens().catch(error => {
81:   console.error('❌ Error:', error.message);
82:   process.exit(1);
83: });
