 273: ## Day 2: Core Mapping Implementation
 274: 
 275: **Goal**: Implement schema.org serialization for CalendarEvent and related types
 276: 
 277: ### Morning (2 hours)
 278: 
 279: #### 2.1 Create Serializer Service (1.5 hours)
 280: 
 281: Create `src/services/SchemaOrgSerializer.ts`:
 282: 
 283: ```typescript
 284: import { CalendarEvent, CalendarEventAttendee, CalendarListEntry } from '../schemas/types';
 285: 
 286: export interface SchemaOrgEvent {
 287:   '@context': 'https://schema.org';
 288:   '@type': 'Event';
 289:   identifier?: string | null;
 290:   name?: string | null;
 291:   startDate?: string | null;
 292:   endDate?: string | null;
 293:   location?: string | null;
 294:   attendee?: SchemaOrgPerson[];
 295:   organizer?: SchemaOrgPerson | null;
 296:   description?: string | null;
 297:   url?: string | null;
 298:   color?: string | null;
 299: }
 300: 
 301: export interface SchemaOrgPerson {
 302:   '@type': 'Person';
 303:   email?: string | null;
 304:   name?: string | null;
 305:   url?: string | null;
 306: }
 307: 
 308: export class SchemaOrgSerializer {
 309:   /**
 310:    * Convert CalendarEvent to schema.org Event
 311:    */
 312:   serializeEvent(event: CalendarEvent): SchemaOrgEvent {
 313:     return {
 314:       '@context': 'https://schema.org',
 315:       '@type': 'Event',
 316:       identifier: event.id,
 317:       name: event.summary,
 318:       startDate: this.formatDateTime(event.start),
 319:       endDate: this.formatDateTime(event.end),
 320:       location: event.location,
 321:       attendee: this.serializeAttendees(event.attendees),
 322:       description: event.description,
 323:       url: event.htmlLink,
 324:       color: this.mapColorId(event.colorId),
 325:     };
 326:   }
 327: 
 328:   /**
 329:    * Convert CalendarEvent[] to schema.org Event[]
 330:    */
 331:   serializeEvents(events: CalendarEvent[]): SchemaOrgEvent[] {
 332:     return events.map(event => this.serializeEvent(event));
 333:   }
 334: 
 335:   /**
 336:    * Format start/end datetime with timezone
 337:    * Input: { dateTime: "2026-03-24T10:00", timeZone: "America/Los_Angeles" }
 338:    * Output: "2026-03-24T10:00:00-07:00"
 339:    */
 340:   private formatDateTime(dt: CalendarEvent['start'] | CalendarEvent['end'] | undefined): string | null {
 341:     if (!dt) return null;
 342: 
 343:     // All-day event (no time component)
 344:     if (dt.date && !dt.dateTime) {
 345:       return dt.date; // ISO 8601 date: YYYY-MM-DD
 346:     }
 347: 
 348:     // Datetime with timezone
 349:     if (dt.dateTime && dt.timeZone) {
 350:       // TODO: Convert timezone to UTC offset
 351:       // For now, return ISO string
 352:       return this.convertToIso8601WithOffset(dt.dateTime, dt.timeZone);
 353:     }
 354: 
 355:     if (dt.dateTime) {
 356:       return dt.dateTime;
 357:     }
 358: 
 359:     return null;
 360:   }
 361: 
 362:   /**
 363:    * Convert timezone-aware datetime to ISO 8601 with UTC offset
 364:    * Requires: date-fns or similar library for timezone handling
 365:    */
 366:   private convertToIso8601WithOffset(dateTime: string, timeZone: string): string {
 367:     // TODO: Implement timezone conversion
 368:     // This is complex - may need date-fns or luxon library
 369:     // For MVP: return dateTime as-is, handle in Phase 2
 370:     return dateTime;
 371:   }
 372: 
 373:   /**
 374:    * Convert attendees to schema.org Person objects
 375:    */
 376:   private serializeAttendees(attendees: CalendarEventAttendee[] | null | undefined): SchemaOrgPerson[] | undefined {
 377:     if (!attendees || attendees.length === 0) return undefined;
 378: 
 379:     return attendees.map(attendee => ({
 380:       '@type': 'Person',
 381:       email: attendee.email,
 382:       name: attendee.displayName, // If available
 383:       url: undefined, // Could be calendar profile URL
 384:     })).filter(p => p.email || p.name); // Only include attendees with email/name
 385:   }
 386: 
 387:   /**
 388:    * Map Google Calendar colorId to schema.org color name
 389:    */
 390:   private mapColorId(colorId: string | null | undefined): string | undefined {
 391:     const colorMap: Record<string, string> = {
 392:       '1': 'tomato',
 393:       '2': 'flamingo',
 394:       '3': 'tangerine',
 395:       '4': 'banana',
 396:       '5': 'sage',
 397:       '6': 'basil',
 398:       '7': 'peacock',
 399:       '8': 'blueberry',
 400:       '9': 'lavender',
 401:       '10': 'grape',
 402:       '11': 'graphite',
 403:     };
 404: 
 405:     return colorId ? colorMap[colorId] : undefined;
 406:   }
 407: }
 408: ```
 409: 
 410: **Checklist**:
 411: - [x] Create file with imports
 412: - [x] Define SchemaOrgEvent interface
 413: - [x] Define SchemaOrgPerson interface
 414: - [x] Implement serializeEvent()
 415: - [x] Implement serializeEvents()
 416: - [x] Implement helper methods
 417: - [x] Add JSDoc comments
 418: - [x] Test file compiles: `npx tsc --noEmit`
 419: 
 420: #### 2.2 Create Unit Tests (0.5 hours)
 421: 
 422: Create `src/tests/unit/services/SchemaOrgSerializer.test.ts`:
 423: 
