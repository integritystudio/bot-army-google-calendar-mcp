 13:     });
 14: 
 15:     const messageIds = response.data.messages || [];
 16:     console.log(`Found ${messageIds.length} unread messages\n`);
 17: 
 18:     const messages = await Promise.all(
 19:       messageIds.map(async (msg) => {
 20:         try {
 21:           const fullMsg = await gmail.users.messages.get({
 22:             userId: USER_ID,
 23:             id: msg.id,
 24:             format: "metadata",
 25:             metadataHeaders: ["Subject", "From", "Date"]
 26:           });
 27: 
 28:           const headers = fullMsg.data.payload?.headers || [];
 29:           return {
 30:             id: msg.id,
 31:             subject: getHeader(headers, 'Subject', '(No subject)'),
 32:             from: getHeader(headers, 'From', '(Unknown sender)'),
 33:             date: getHeader(headers, 'Date'),
 34:             snippet: fullMsg.data.snippet || ''
 35:           };
 36:         } catch (error) {
 37:           return null;
 38:         }
 39:       })
 40:     );
 41: 
 42:     const validMessages = messages.filter(m => m !== null);
 43: 
 44:     const categorized = {
 45:       highUrgencyHighImportance: [],
 46:       highUrgencyMediumImportance: [],
 47:       highUrgencyLowImportance: [],
 48:       mediumUrgencyHighImportance: [],
 49:       mediumUrgencyMediumImportance: [],
 50:       mediumUrgencyLowImportance: [],
 51:       lowUrgencyHighImportance: [],
 52:       lowUrgencyMediumImportance: [],
 53:       lowUrgencyLowImportance: []
 54:     };
 55: 
 56:     validMessages.forEach(msg => {
 57:       const { urgency, importance } = categorizeEmail(msg);
 58:       
 59:       const key = `${urgency}Urgency${importance}Importance`;
 60:       if (categorized[key]) {
 61:         categorized[key].push(msg);
 62:       }
 63:     });
 64: 
 65:     outputResults(categorized);
 66: 
 67:   } catch (error) {
 68:     console.error('Error:', error instanceof Error ? error.message : error);
 69:     process.exit(1);
 70:   }
 71: }
 72: 
 73: function categorizeEmail(msg) {
 74:   const subject = msg.subject.toLowerCase();
 75:   const from = msg.from.toLowerCase();
 76:   const snippet = msg.snippet.toLowerCase();
 77:   const content = `${subject} ${from} ${snippet}`;
 78: 
 79:   let urgency = 'medium';
 80:   const highUrgencyKeywords = [
 81:     'urgent', 'asap', 'immediate', 'urgent action', 'critical',
 82:     'emergency', 'alert', 'action required', 'deadline today',
 83:     'review needed today'
 84:   ];
 85: 
 86:   const lowUrgencyKeywords = [
 87:     'fyi', 'newsletter', 'digest', 'weekly', 'monthly',
 88:     'update', 'news', 'magazine', 'notification'
 89:   ];
 90: 
 91:   if (highUrgencyKeywords.some(kw => content.includes(kw))) {
 92:     urgency = 'high';
 93:   } else if (lowUrgencyKeywords.some(kw => content.includes(kw))) {
 94:     urgency = 'low';
 95:   }
 96: 
 97:   let importance = 'medium';
 98:   const highImportanceKeywords = [
 99:     'boss', 'manager', 'ceo', 'cto', 'director',
100:     'invoice', 'payment', 'contract', 'proposal',
101:     'approved', 'rejected', 'decision', 'approval',
102:     'meeting', 'urgent meeting', 'all hands'
103:   ];
104: 
105:   const lowImportanceKeywords = [
106:     'marketing', 'promotion', 'sale', 'discount',
107:     'follow us', 'subscribe', 'unsubscribe', 'social'
108:   ];
109: 
110:   if (highImportanceKeywords.some(kw => content.includes(kw))) {
111:     importance = 'high';
112:   } else if (lowImportanceKeywords.some(kw => content.includes(kw))) {
113:     importance = 'low';
114:   }
115: 
116:   return { urgency, importance };
117: }
118: 
119: function outputResults(categorized) {
